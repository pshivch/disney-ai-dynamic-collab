   "source": [
    "# Payoff matrix + minimax search\n",
    "M = np.array([[ 0.2,-0.1, 0.3,-0.2],\n",
    "              [-0.1, 0.1,-0.2, 0.4],\n",
    "              [ 0.3,-0.2, 0.2,-0.1],\n",
    "              [-0.2, 0.4,-0.1, 0.1]])\n",
    "\n",
    "grid = np.linspace(0,1,51)\n",
    "def simplex4():\n",
    "    for a in grid:\n",
    "        for b in grid:\n",
    "            for c in grid:\n",
    "                d = 1-a-b-c\n",
    "                if d>=0: yield np.array([a,b,c,d],float)\n",
    "\n",
    "Y = list(simplex4())\n",
    "best_val, best_x = float(\"inf\"), None\n",
    "for x in simplex4():\n",
    "    v = max(float(x @ M @ y) for y in Y)\n",
    "    if v < best_val: best_val, best_x = v, x\n",
    "best_y = Y[int(np.argmin([float(best_x @ M @ y) for y in Y]))]\n",
    "minimax_value = float(best_val)\n",
    "minimax_value"
   ]
  },
